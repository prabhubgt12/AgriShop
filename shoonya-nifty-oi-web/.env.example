# Shoonya OAuth — https://github.com/kambalatech/NorenApi-js style + Shoonya endpoints
SHOONYA_USERID=
# Client ID from Shoonya → API → API Key (NOT the old vendor code FA41572_U unless shown there)
SHOONYA_CLIENT_ID=
SHOONYA_SECRET_CODE=

# Login page (pick one):
# A) Open Shoonya web app — log in, then authorize API (recommended default)
SHOONYA_OAUTH_URL=https://api.shoonya.com/OAuthlogin
# B) Direct login form with API key (Python GetAuthcode style):
# SHOONYA_OAUTH_USE_TRADE_LOGIN=true
# SHOONYA_OAUTH_URL=https://trade.shoonya.com/OAuthlogin/investor-entry-level/login

# Optional: append ?client_id= to OAuthlogin (usually not needed)
# SHOONYA_OAUTH_APPEND_CLIENT_ID=true

# Optional: skip UI login if you already have a token
SHOONYA_ACCESS_TOKEN=
SHOONYA_ACCOUNT_ID=

PORT=3000
POLL_SECONDS=5
STRIKE_STEP=50
STRIKES_EACH_SIDE=8
EXPIRY_SEARCH_TEXT=NIFTY
