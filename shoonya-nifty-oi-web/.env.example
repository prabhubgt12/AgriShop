SHOONYA_USERID=
SHOONYA_CLIENT_ID=
SHOONYA_SECRET_CODE=
SHOONYA_PASSWORD=
SHOONYA_TOTP_SECRET=

# Optional: GetAuthcode-style login URL (default is trade OAuth investor login)
# SHOONYA_AUTO_LOGIN_URL=https://trade.shoonya.com/OAuthlogin/investor-entry-level/login
# SHOONYA_AUTO_LOGIN_HEADLESS=true

SHOONYA_ACCESS_TOKEN=
SHOONYA_ACCOUNT_ID=

PORT=3000
POLL_SECONDS=5
STRIKE_STEP=50
STRIKES_EACH_SIDE=8
EXPIRY_SEARCH_TEXT=NIFTY

# API orders: Shoonya rejects MKT (ALGO_CHK). App sends LMT with slippage vs LTP.
SHOONYA_API_SLIPPAGE_PCT=3
SHOONYA_NFO_TICK_SIZE=0.05

# NORMAL mode: NIFTY must move this many points past breakoutLevel before FALSE_BREAKOUT exit
# PE exits when spot > breakoutLevel + buffer; CE when spot < breakoutLevel - buffer
FALSE_BREAKOUT_BUFFER_POINTS=15
